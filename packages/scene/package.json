{
  "name": "@editrix/scene",
  "version": "0.1.0",
  "description": "Scene-domain types for game/3D editors built on Editrix",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
