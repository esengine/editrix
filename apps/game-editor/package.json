{
  "name": "@editrix/game-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Game editor built with Editrix framework",
  "main": "src/main.cjs",
  "type": "module",
  "scripts": {
    "build": "esbuild src/renderer.ts --bundle --outfile=dist/renderer.js --format=esm --platform=browser --target=es2022 --sourcemap --packages=bundle && esbuild src/launcher.ts --bundle --outfile=dist/launcher.js --format=esm --platform=browser --target=es2022 --sourcemap",
    "build:wasm": "node scripts/build-wasm.js",
    "build:wasm:all": "node scripts/build-wasm.js --all",
    "copy:wasm": "node -e \"const{cpSync,mkdirSync}=require('fs'),p=require('path');const s=p.resolve(__dirname,'../../vendor/estella/build/build-web/sdk'),d=p.resolve(__dirname,'wasm');mkdirSync(d,{recursive:true});for(const f of['esengine-core.js','esengine-core.wasm']){const src=p.join(s,f),dst=p.join(d,f.replace('esengine-core','esengine'));try{cpSync(src,dst);console.log('Copied',f)}catch{console.warn('Skip',f)}}\"",
    "start": "npm run build && electron src/main.cjs"
  },
  "dependencies": {
    "@editrix/common": "workspace:*",
    "@editrix/core": "workspace:*",
    "@editrix/estella": "workspace:*",
    "@editrix/plugin-console": "workspace:*",
    "@editrix/properties": "workspace:*",
    "@editrix/plugin-manager": "workspace:*",
    "@editrix/plugin-settings": "workspace:*",
    "@editrix/scene": "workspace:*",
    "@editrix/shell": "workspace:*",
    "@editrix/view-dom": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "electron": "^35.0.0"
  }
}
