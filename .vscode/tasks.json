{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:game-editor",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@editrix/game-editor", "build"],
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build:all",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "test:all",
      "type": "shell",
      "command": "pnpm",
      "args": ["test"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
